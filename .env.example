# Required: OpenAI API key for receipt parsing
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Database URL (defaults to SQLite)
# DATABASE_URL=sqlite:///receipts.db

# Optional: User email for single-user mode (defaults to user@receipts.local)
# DEFAULT_USER_EMAIL=your-email@example.com

# Optional: Execution mode - dev (default), local, or cloud
# EXECUTION_MODE=dev
