# Environment configuration
ENVIRONMENT=development
# Options: development, production, test

# Execution mode - controls parallelism profile
# dev: Safe, single-threaded for development (default)
# local: Limited parallelism for local batch processing (2 workers)
# cloud: Scalable parallelism for cloud deployment (4 workers)
EXECUTION_MODE=dev

# Concurrency control (overrides mode defaults if set)
# MAX_WORKERS: Number of parallel workers for batch processing
# OCR_THREADS: Number of threads for OCR (MUST be 1 if MAX_WORKERS > 1)
# MAX_WORKERS=2
# OCR_THREADS=1

# OpenAI API configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Database configuration
# For SQLite (default):
# DATABASE_URL=sqlite:///receipts.db
# DATABASE_URL=sqlite:///test_receipts.db  # For testing
# For PostgreSQL:
DATABASE_URL=postgresql://username:password@localhost:5432/receipts_db

# User configuration
DEFAULT_USER_EMAIL=your-email@example.com
MULTI_USER_MODE=false

# Logging configuration
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# Processing configuration
MAX_RETRY_ATTEMPTS=3

# Token usage tracking
TOKEN_USAGE_FILE=token_usage.json
